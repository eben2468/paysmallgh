# PaySmallSmall — front controller routing for shared hosting where the
# document root IS the project root (all files in public_html). Apache.
#
# Homepage works without this (Apache auto-serves index.php for "/"), but every
# other URL — /shop, /assets/css/app.css, etc. — needs these rules to reach the
# app. If styling/pages 404, this file is missing or not being read.

RewriteEngine On

# --- Security: never serve source, DB scripts, or VCS from the web -----------
RewriteRule ^(app|database|scripts|\.git)/ - [F,L]

# --- Serve real files/folders directly ---------------------------------------
# (Assets live under /public and are streamed by index.php below, so they fall
#  through to the front controller.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --- Everything else -> front controller -------------------------------------
# index.php (root) hands off to public/index.php, which also serves /assets and
# /uploads with the correct MIME types.
RewriteRule ^ index.php [L]

# --- Hard-deny the environment file even if rewriting is off -----------------
<Files ".env">
  Require all denied
</Files>
<Files ".env.example">
  Require all denied
</Files>
