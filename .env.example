# PaySmallSmall environment config. Copy to .env and fill in.

APP_NAME="PaySmallSmall"
APP_URL=http://localhost/payss/public
APP_DEBUG=true

DB_HOST=localhost
DB_PORT=3306
DB_NAME=paysmallsmall
DB_USER=root
DB_PASS=

# mock | sandbox | live
# mock: payments succeed instantly against the local simulator. Demo-safe.
# sandbox/live: real Moolre API calls. Confirm endpoint paths on docs.moolre.com first.
PAYMENTS_MODE=mock

# Moolre credentials (only needed for sandbox/live)
MOOLRE_BASE_URL=https://api.moolre.com
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_API_PUBKEY=
MOOLRE_VAS_KEY=
MOOLRE_ACCOUNT_NUMBER=
# Endpoint paths — confirm against docs.moolre.com before going live. Do not guess.
MOOLRE_PATH_COLLECT=/open/transact/payment
MOOLRE_PATH_DISBURSE=/open/transact/transfer
MOOLRE_PATH_STATUS=/open/transact/status
MOOLRE_PATH_SMS=/open/vas/sms
MOOLRE_CURRENCY=GHS
# Channel/network codes — CONFIRM against docs.moolre.com before going live.
MOOLRE_CHANNEL_MOMO=13
MOOLRE_CHANNEL_BANK=14
# Public URL Moolre POSTs payment confirmations to (must match the webhook route)
MOOLRE_CALLBACK_URL=https://your-domain/webhook/moolre
# Shared secret for verifying webhook calls (set the same value in the Moolre dashboard)
MOOLRE_WEBHOOK_SECRET=change-me
# Reconcile pending payments older than this many minutes (status-check fallback)
RECONCILE_AFTER_MINUTES=2

# Fees, in percent
PLATFORM_FEE_PCT=5
CANCEL_FEE_PCT=5

# Grace period for missed payments, in days
GRACE_DAYS=3

# Admin login
ADMIN_PHONE=233000000000
ADMIN_PASSWORD=change-me

# USSD short code shown on the site (assigned by Moolre)
USSD_CODE=*920*77#
